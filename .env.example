# =============================================================================
# Georges Medical Chatbot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Flask Application
# -----------------------------------------------------------------------------

# Secret key for Flask session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Flask environment: "development" or "production"
FLASK_ENV=development

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------

# Secret key for signing JWT tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=change-me-to-another-random-64-char-hex-string

# -----------------------------------------------------------------------------
# Database - MongoDB
# -----------------------------------------------------------------------------

# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017/georges_medical

# Database name
MONGO_DB_NAME=georges_medical

# Database backend driver: "pymongo" or "motor" (async)
DB_BACKEND=pymongo

# -----------------------------------------------------------------------------
# Elasticsearch
# -----------------------------------------------------------------------------

# Elasticsearch host URL
ELASTIC_HOST=http://localhost:9200

# Prefix for all Elasticsearch index names (e.g., "georges_conversations", "georges_users")
ELASTIC_INDEX_PREFIX=georges

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------

# AES-256 encryption key for sensitive patient data (exactly 32 bytes, base64-encoded)
# Generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=Y2hhbmdlLW1lLXRvLWEtcmVhbC0zMi1ieXRlLWtleQ==

# -----------------------------------------------------------------------------
# LLM Service (Gemini)
# -----------------------------------------------------------------------------

# Google Gemini API key (obtain from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Internal URL of the LLM microservice
LLM_SERVICE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Email - Mailgun
# -----------------------------------------------------------------------------

# Mailgun API key for sending transactional emails (password resets, notifications)
MAILGUN_API_KEY=key-your-mailgun-api-key

# Mailgun sending domain
MAILGUN_DOMAIN=mg.yourdomain.com

# -----------------------------------------------------------------------------
# LDAP (Optional - for hospital directory authentication)
# -----------------------------------------------------------------------------

# LDAP server URL (leave empty to disable LDAP auth)
LDAP_SERVER=

# Base DN for LDAP user searches
LDAP_BASE_DN=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins for cross-origin requests
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------

# Public URL of the frontend (used in emails and redirects)
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Default rate limit for all endpoints (requests per period)
RATELIMIT_DEFAULT=200 per hour

# Rate limit storage backend URI (use memory:// for development)
RATELIMIT_STORAGE_URI=memory://

# Rate limit for authentication endpoints
RATELIMIT_AUTH=10 per minute

# Rate limit for LLM generation endpoints
RATELIMIT_LLM=30 per minute

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
